{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "lib": ["esnext"],
        "target": "ESNext",
        "isolatedModules": true,
        "moduleResolution": "NodeNext",
        "module": "NodeNext",
        "strict": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "declaration": true,
        "types": ["jest", "node"]
    },
    "ts-node": {
        "esm": true,
        "experimentalEsm": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["dist", "client", "node_modules"]
}