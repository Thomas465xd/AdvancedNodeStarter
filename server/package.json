{
	"name": "server",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"main": "index.js",
	"scripts": {
		"start": "node --loader ts-node/esm src/index.ts",
		"server": "nodemon --exec \"node --loader ts-node/esm\" src/index.ts --trace-warnings",
		"client": "npm run start --prefix ../client",
		"dev": "concurrently \"npm run server\" \"npm run client\"",
		"tests": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watchAll",
		"test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
		"build": "cross-env NPM_CONFIG_PRODUCTION=false npm install --legacy-peer-deps --prefix ../client && npm run build --prefix ../client",
		"heroku-postbuild": "npm run build"
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"aws-sdk": "2.188.0",
		"body-parser": "1.17.2",
		"concurrently": "3.5.0",
		"cookie-session": "^2.1.1",
		"dotenv": "^16.4.7",
		"express": "4.15.3",
		"migrate-mongoose": "3.2.2",
		"mongoose": "9.3.0 ",
		"morgan": "^1.10.1",
		"passport": "0.3.2",
		"passport-google-oauth20": "2.0.0",
		"path-parser": "2.0.2",
		"puppeteer": "^24.0.0",
		"redis": "^5.11.0",
		"uuid": "3.2.1"
	},
	"devDependencies": {
		"@types/bcrypt": "^5.0.2",
		"@types/cookie-session": "^2.0.49",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.3",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.8",
		"@types/morgan": "^1.9.10",
		"@types/node": "^25.4.0",
		"@types/passport": "^1.0.17",
		"@types/passport-google-oauth20": "^2.0.17",
		"@types/supertest": "^6.0.3",
		"cross-env": "^10.1.0",
		"jest": "^30.2.0",
		"mongodb-memory-server": "^10.4.1",
		"nodemon": "^3.1.9",
		"supertest": "^7.1.4",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3"
	}
}
